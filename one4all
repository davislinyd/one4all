#!/usr/bin/env python3
import os
import sys
import json
import re
import shutil
import platform
import subprocess

# 取得腳本所在目錄，確保正確讀取設定檔與範本
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
CONFIG_FILE = os.path.join(SCRIPT_DIR, "one4all.json")
OS_TYPE = platform.system()

def load_config():
    """載入 one4all.json 設定檔"""
    if not os.path.exists(CONFIG_FILE):
        print(f"錯誤: 找不到設定檔 {CONFIG_FILE}", file=sys.stderr)
        sys.exit(1)
    try:
        with open(CONFIG_FILE, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception as e:
        print(f"錯誤: 解析 one4all.json 失敗。{e}", file=sys.stderr)
        sys.exit(1)

def check_pm2():
    """確認 PM2 是否已安裝"""
    # 擴展 PATH 以便在 macOS/Linux 上找到 Homebrew 等目錄下的命令
    env = os.environ.copy()
    extra_paths = ["/opt/homebrew/bin", "/usr/local/bin", "/usr/sbin", "/sbin"]
    env["PATH"] = os.path.pathsep.join(extra_paths) + os.path.pathsep + env.get("PATH", "")
    
    pm2_path = shutil.which("pm2", path=env["PATH"])
    if not pm2_path:
        print("錯誤: 系統未安裝 pm2。請先安裝 Node.js 並執行: npm install -g pm2", file=sys.stderr)
        sys.exit(1)
    return pm2_path, env

def run_command(args, cwd=None, env=None, check=False):
    """封裝 subprocess 呼叫"""
    try:
        result = subprocess.run(
            args, cwd=cwd, env=env, text=True, capture_output=True
        )
        if check and result.returncode != 0:
            print(f"指令執行失敗: {' '.join(args)}", file=sys.stderr)
            if result.stderr:
                print(result.stderr, file=sys.stderr)
            sys.exit(result.returncode)
        return result
    except Exception as e:
        print(f"執行指令時發生異常: {e}", file=sys.stderr)
        sys.exit(1)

def manage_services(action):
    """執行後端服務管理 (start/stop/restart)"""
    pm2_path, env = check_pm2()
    config = load_config()
    services = config.get("services", [])
    
    if not services:
        print("提示: 設定檔中無定義任何服務。")
        return

    print(f"\n=== 執行後端服務操作: {action} ===")
    for s in services:
        name = s.get("name")
        cwd = s.get("cwd", ".")
        script = s.get("script")
        interpreter = s.get("interpreter", "python3")
        args_str = s.get("args", "")
        
        # 處理相對路徑
        abs_cwd = cwd
        if cwd.startswith("."):
            abs_cwd = os.path.normpath(os.path.join(SCRIPT_DIR, cwd))

        if action == "start":
            print(f"正在啟動服務: {name} (在 {abs_cwd})...")
            if not os.path.isdir(abs_cwd):
                print(f" 警告: 目錄 {abs_cwd} 不存在，跳過此服務。")
                continue
            
            cmd = [pm2_path, "start", script, "--name", name, "--interpreter", interpreter]
            if args_str:
                cmd += ["--"] + args_str.split()
                
            run_command(cmd, cwd=abs_cwd, env=env)
            
        elif action == "stop":
            print(f"正在停止服務: {name}...")
            # 停止服務，如果本來就沒啟動則忽略錯誤
            run_command([pm2_path, "stop", name], env=env)
            
        elif action == "restart":
            print(f"正在重啟服務: {name}...")
            # 檢查服務是否已在 PM2 列表中
            desc = run_command([pm2_path, "describe", name], env=env)
            if desc.returncode == 0:
                run_command([pm2_path, "restart", name], env=env)
            else:
                # 若不存在則直接 start
                if not os.path.isdir(abs_cwd):
                    print(f" 警告: 目錄 {abs_cwd} 不存在，跳過此服務。")
                    continue
                cmd = [pm2_path, "start", script, "--name", name, "--interpreter", interpreter]
                if args_str:
                    cmd += ["--"] + args_str.split()
                run_command(cmd, cwd=abs_cwd, env=env)

def reload_nginx():
    """動態生成與重載 Nginx 設定"""
    print("\n=== 正在測試與重載 Nginx ===")
    config = load_config()
    nginx_port = config.get("nginx", {}).get("port", 9002)

    # 1. 偵測 nginx 執行路徑
    env = os.environ.copy()
    extra_paths = ["/opt/homebrew/bin", "/usr/local/bin", "/usr/sbin", "/sbin"]
    env["PATH"] = os.path.pathsep.join(extra_paths) + os.path.pathsep + env.get("PATH", "")
    
    nginx_cmd = shutil.which("nginx", path=env["PATH"])
    if not nginx_cmd:
        # 常見預設路徑備用
        for p in ["/opt/homebrew/bin/nginx", "/usr/local/bin/nginx", "/usr/sbin/nginx"]:
            if os.path.exists(p):
                nginx_cmd = p
                break
                
    if not nginx_cmd:
        print("警告: 找不到 nginx 執行檔，跳過 Nginx 重載。請手動重載 Nginx。", file=sys.stderr)
        return

    # 2. 決定目標設定檔寫入路徑
    if OS_TYPE == "Darwin":
        if os.path.isdir("/opt/homebrew/etc/nginx/servers"):
            target_nginx_conf = "/opt/homebrew/etc/nginx/servers/one4all.conf"
        else:
            target_nginx_conf = "/usr/local/etc/nginx/servers/one4all.conf"
    else:
        target_nginx_conf = "/etc/nginx/sites-available/one4all"

    # 3. 讀取範本並動態修改 Port
    template_path = os.path.join(SCRIPT_DIR, "nginx.conf")
    if not os.path.exists(template_path):
        print(f"錯誤: 找不到 Nginx 範本檔案 {template_path}", file=sys.stderr)
        return

    print(f"正在將 Nginx 對外 Port 設定為 {nginx_port} (寫入至 {target_nginx_conf})...")
    try:
        with open(template_path, "r", encoding="utf-8") as f:
            nginx_content = f.read()
            
        # 替換 listen 埠
        updated_content = re.sub(r"listen\s+\d+;", f"listen {nginx_port};", nginx_content)
        
        with open(target_nginx_conf, "w", encoding="utf-8") as f:
            f.write(updated_content)
    except PermissionError:
        print("錯誤: 權限不足，無法寫入 Nginx 設定檔！", file=sys.stderr)
        print("提示: 請嘗試以管理員權限執行 (例如: sudo ./one4all reload)。", file=sys.stderr)
        return
    except Exception as e:
        print(f"錯誤: 生成 Nginx 設定檔失敗。{e}", file=sys.stderr)
        return

    # 4. 測試 Nginx 設定檔
    print("測試 Nginx 設定檔語法...")
    test_cmd = [nginx_cmd, "-t"]
    if OS_TYPE != "Darwin":
        test_cmd = ["sudo"] + test_cmd
        
    test_res = run_command(test_cmd, env=env)
    if test_res.returncode == 0:
        print("Nginx 設定語法正確。")
    else:
        print("錯誤: Nginx 設定語法測試失敗！", file=sys.stderr)
        if test_res.stderr:
            print(test_res.stderr, file=sys.stderr)
        return

    # 5. 重載 Nginx
    print("正在重載 Nginx 服務...")
    if OS_TYPE == "Darwin":
        reload_cmd = [nginx_cmd, "-s", "reload"]
    else:
        if shutil.which("systemctl"):
            reload_cmd = ["sudo", "systemctl", "reload", "nginx"]
        else:
            reload_cmd = ["sudo", "service", "nginx", "reload"]
            
    reload_res = run_command(reload_cmd, env=env)
    if reload_res.returncode == 0:
        print("Nginx 重載成功！")
    else:
        print("錯誤: Nginx 重載失敗。", file=sys.stderr)
        if reload_res.stderr:
            print(reload_res.stderr, file=sys.stderr)

def show_usage():
    print(f"使用方式: {sys.argv[0]} {{start|stop|restart|reload|status}}")
    print("  start   : 啟動 one4all.json 中定義的所有後端服務")
    print("  stop    : 停止所有後端服務")
    print("  restart : 重啟所有後端服務")
    print("  reload  : 重啟所有後端服務並重載 Nginx")
    print("  status  : 查看所有後端服務運行狀態 (PM2 list)")

def main():
    if len(sys.argv) < 2:
        show_usage()
        sys.exit(1)
        
    action = sys.argv[1]
    
    if action == "start":
        manage_services("start")
    elif action == "stop":
        manage_services("stop")
    elif action == "restart":
        manage_services("restart")
    elif action == "reload":
        manage_services("restart")
        reload_nginx()
    elif action == "status":
        pm2_path, env = check_pm2()
        subprocess.run([pm2_path, "list"], env=env)
    else:
        show_usage()
        sys.exit(1)

if __name__ == "__main__":
    main()
