{
  "nginx": {
    "config_name": "one4all.conf"
  },
  "services": [
    {
      "name": "service1",
      "port": 8085,
      "script": "app.py",
      "cwd": "./services/service1",
      "interpreter": "python3",
      "args": "--port {{.Port}}",
      "proxy": {
        "type": "direct",
        "external_port": 443
      }
    },
    {
      "name": "video2gif",
      "port": 9003,
      "script": "app.py",
      "cwd": "./services/video2gif",
      "interpreter": "python3",
      "args": "--port {{.Port}}",
      "proxy": {
        "type": "path",
        "external_port": 9002,
        "path": "/video2gif/",
        "extra_paths": [
          {
            "path": "/convert",
            "backend_path": "/convert"
          }
        ]
      }
    },
    {
      "name": "another_app",
      "port": 9004,
      "script": "app.py",
      "cwd": "./services/another_app",
      "interpreter": "python3",
      "args": "--port {{.Port}}",
      "proxy": {
        "type": "path",
        "external_port": 9002,
        "path": "/another_app/"
      }
    },
    {
      "name": "internet_proxy_test",
      "port": 0,
      "script": "",
      "cwd": "",
      "interpreter": "",
      "args": "",
      "proxy": {
        "type": "direct",
        "external_port": 9010,
        "proxy_pass": "https://example.com/"
      }
    }
  ]
}
