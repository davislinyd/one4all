# One for All - Dynamic Nginx Reverse Proxy Configuration
# This file is auto-generated by one4all Go CLI. Do not modify manually!

# Dynamic handler for WebSocket Upgrade
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      '';
}

{{ range . }}
# ==================== SERVER BLOCK (Port: {{ .Port }}) ====================
server {
    listen {{ .Port }};
    server_name localhost;

    {{ range .Locations }}
    # Proxy {{ .Path }} ➜ {{ .BackendURL }}
    location {{ .Path }} {
        proxy_pass {{ .BackendURL }};
        
        proxy_set_header Host {{ .HostHeader }};
        {{ if .EnableSSLName }}
        # SNI configuration required for proxying to HTTPS external websites
        proxy_ssl_server_name on;
        {{ end }}

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Long-connection tuning for SSE (Server-Sent Events) and WebSockets
        proxy_buffering off;
        proxy_cache off;
        chunked_transfer_encoding on;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
        tcp_nodelay on;

        # Request payload body size limit for large files
        client_max_body_size 50M;
    }
    {{ end }}
}
{{ end }}
