# One for All - Dynamic Nginx Reverse Proxy Configuration
# 此檔案由 one4all Go CLI 自動生成，請勿手動修改！

# 動態處理 WebSocket Upgrade
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      '';
}

{{ range . }}
# ==================== SERVER BLOCK (Port: {{ .Port }}) ====================
server {
    listen {{ .Port }};
    server_name localhost;

    {{ range .Locations }}
    # 代理 {{ .Path }} ➜ 后端 Port {{ .BackendPort }}
    location {{ .Path }} {
        proxy_pass http://127.0.0.1:{{ .BackendPort }}{{ .BackendPath }};
        
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # 針對 SSE (Server-Sent Events) 與 WebSocket 的長連線優化
        proxy_buffering off;
        proxy_cache off;
        chunked_transfer_encoding on;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
        tcp_nodelay on;

        # 針對大檔案傳輸的 Body 大小限制
        client_max_body_size 50M;
    }
    {{ end }}
}
{{ end }}
